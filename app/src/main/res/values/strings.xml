    <string name="onboarding_1_title">Your phone, your controller</string>
    <string name="onboarding_1_body">Turn your phone into a wireless gamepad for PCs, tablets, and other compatible devices via Bluetooth.</string>

    <string name="onboarding_2_title">Play your way</string>
    <string name="onboarding_2_body">Use the virtual touchscreen controls or connect a physical controller via USB cable for a more familiar feel.</string>

    <string name="onboarding_3_title">Record and replay</string>
    <string name="onboarding_3_body">Capture gameplay routines and replay them later. Enable Assisted Recording for more consistent results.</string>

    <string name="onboarding_4_title">About Bluetooth</string>
    <string name="onboarding_4_body">While acting as a wireless controller, Bluetooth gamepads connected to your phone will disconnect.\n\nTo record with a physical controller, connect it via USB cable.</string>

    <string name="onboarding_5_title">Ready to go</string>
    <string name="onboarding_5_body">Grant Bluetooth permissions when prompted and start playing. You can fine-tune everything in Settings.</string>

